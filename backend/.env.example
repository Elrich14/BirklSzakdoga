# --- Database (required) -----------------------------------------------------
# Default: Supabase managed Postgres. Copy the connection parameters from
# Project Settings -> Database in the Supabase dashboard.
# SSL is auto-enabled in code when DB_HOST contains "supabase".
DB_HOST=db.<your-project-ref>.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-supabase-password
DB_NAME=postgres
#
# Fallback: local Docker Postgres from docker-compose.yml. Use these values
# instead if you want to develop without a Supabase project:
#   DB_HOST=db ; DB_PORT=5432 ; DB_USER=postgres ; DB_PASSWORD=postgres ; DB_NAME=kerian

# --- JWT (required) ----------------------------------------------------------
# Use a long random string (32+ chars). Example: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-long-random-string

# --- TOTP / admin 2FA (required for admin login) -----------------------------
# 32-byte base64 key used to encrypt admin TOTP secrets at rest.
# Generate: openssl rand -base64 32
TOTP_ENCRYPTION_KEY=replace-me-with-base64-32-bytes

# --- Email / Nodemailer (order confirmation emails) --------------------------
# Use a Gmail address with an App Password (https://myaccount.google.com/apppasswords)
EMAIL_ADMIN=your.address@gmail.com
EMAIL_PASS=your-gmail-app-password

# --- Cloudinary (product image upload) ---------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- Google OAuth (Sign in with Google) --------------------------------------
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <BACKEND_BASE_URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe (card payment, test mode) ----------------------------------------
# Test secret key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret for verifying Stripe -> backend webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
# EUR -> HUF fallback rate. Normally the live ECB rate is fetched from
# api.frankfurter.app and cached for 1 hour. This value is only used if the
# Frankfurter API is unreachable.
EUR_TO_HUF_RATE=390

# --- Anthropic Claude (AI product recommender on cart page) ------------------
# Without this key the recommender silently falls back to a random selection.
ANTHROPIC_API_KEY=sk-ant-...

# --- Public URLs (used by OAuth and webhook callbacks) -----------------------
# Local dev: BACKEND_BASE_URL=http://localhost:3000, FRONTEND_BASE_URL=http://localhost:3001
BACKEND_BASE_URL=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3001
